# workspace/ 临时工作产物（白皮书草稿、数据集 JSON 等）
workspace/*
!workspace/.gitkeep

# scripts/ 下误建的本地工作目录（含空 sqlite / drnh_images 软链等）
scripts/data/

# notion-drive-worker/ 独立子项目（含 node_modules）；如需入仓应用 git submodule 引入
# 这里临时让顶层仓库忽略它的 node_modules 等编译产物（由子项目自己的 .gitignore 兜底）
notion-drive-worker/node_modules/
notion-drive-worker/dist/
notion-drive-worker/.env*

# DB 不入仓（68MB+ 二进制，备份在 data/backups/）
data/research_index.sqlite
data/research_index.sqlite-journal
data/research_index.sqlite-wal
data/research_index.sqlite-shm
data/backups/
